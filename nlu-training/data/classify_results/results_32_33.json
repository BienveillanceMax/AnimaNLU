  {"text": "Oh ! Buffy", "speech_act": "Greeting", "domain": "Social"},
  {"text": "J'en conclus que vous n'êtes pas médecin", "speech_act": "Statement", "domain": "Social"},
  {"text": "Oh oui. Il a essayé de découper une sculpture de glace en urinant dessus, hein ?", "speech_act": "Question", "domain": "Social"},
  {"text": "Il est musclé, baraqué, plutôt mignon", "speech_act": "Statement", "domain": "Social"},
