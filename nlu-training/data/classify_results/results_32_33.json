  {"text": "Oh joli hâle !", "speech_act": "PositiveFeedback", "domain": "Social"},
  {"text": "C'est probablement ce que j'ai vu", "speech_act": "Statement", "domain": "Social"},
  {"text": "Ouais, c'est ce qu'ils disent tous", "speech_act": "Statement", "domain": "Social"},
  {"text": "Merci Piper !", "speech_act": "PositiveFeedback", "domain": "Social"},
  {"text": "Je voudrais me rapprocher de Lucas", "speech_act": "Statement", "domain": "Social"},
  {"text": "Alors on y va", "speech_act": "Statement", "domain": "Social"},
