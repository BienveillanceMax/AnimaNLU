  {"text": "Oui, vous voulez briser le coeur d'une femme mourante ?", "speech_act": "Question", "domain": "Social"},
  {"text": "Je peux vous aider ?", "speech_act": "Request", "domain": "Social"},
  {"text": "Tu te rends compte, il m'aime !", "speech_act": "ExpressEmotion", "domain": "Social"},
  {"text": "Et vous, il vous faut quelqu'un pour vous raccompagner", "speech_act": "Statement", "domain": "Transport"},
  {"text": "Je n'arrive pas à croire que c'est arrivé", "speech_act": "ExpressEmotion", "domain": "Social"},
  {"text": "Pauvre banc !", "speech_act": "ExpressEmotion", "domain": "Social"},
  {"text": "Ok. Uh, ouais, sur ce, on devrait peut-être y aller", "speech_act": "Request", "domain": "Social"},
  {"text": "Ouais un grand moment", "speech_act": "Statement", "domain": "Social"},
  {"text": "J'adore ces nouveaux avions", "speech_act": "ExpressEmotion", "domain": "Transport"},
  {"text": "Mais ... mais ... c'est affreux", "speech_act": "ExpressEmotion", "domain": "Social"},
