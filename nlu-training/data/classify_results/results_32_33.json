  {"text": "bon voyage, et bon vent !", "speech_act": "Farewell", "domain": "Social"},
  {"text": "Nan, je ne peux pas te laisser prendre ça là-haut", "speech_act": "Deny", "domain": "Social"},
  {"text": "Bataille de bouffe !!!", "speech_act": "Command", "domain": "Social"},
  {"text": "Oui, on comptait te l'annoncer aujourd'hui", "speech_act": "Statement", "domain": "Social"},
