  {"text": "Moi je trouve qu'on va à la bonne vitesse", "speech_act": "Statement", "domain": "Social"},
  {"text": "Moi ? Pourquoi ?", "speech_act": "Question", "domain": "Social"},
  {"text": "Vas-y papa, tu peux réussir !", "speech_act": "Statement", "domain": "Social"},
  {"text": "Ne te gênes pas si tu veux me parler", "speech_act": "Request", "domain": "Communication"},
  {"text": "Ah oui, évidemment ! Tu l'as volée !", "speech_act": "Statement", "domain": "Social"},
  {"text": "Maintenant, il te faut un pseudo", "speech_act": "Statement", "domain": "Social"},
  {"text": "Tu es sûre que tu vas y arriver ?", "speech_act": "Question", "domain": "Social"},
  {"text": "D'accord, allez-y, continuez", "speech_act": "Request", "domain": "Social"},
  {"text": "Je suis contente de te voir moi aussi", "speech_act": "ExpressEmotion", "domain": "Social"},
  {"text": "Bonjour, je suis Marco. Je suis votre serveur", "speech_act": "Greeting", "domain": "Social"},
