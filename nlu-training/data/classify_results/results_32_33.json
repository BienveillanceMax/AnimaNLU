  {"text": "Quel problème on pourrait bien avoir ? On est en vacances", "speech_act": "Question", "domain": "Social"},
  {"text": "La musique c'est", "speech_act": "Statement", "domain": "Media"},
  {"text": "Bonjour Arthur", "speech_act": "Greeting", "domain": "Social"},
  {"text": "C'est bien vrai qu'on peut tomber amoureux au premier coup d'oeil ?", "speech_act": "Question", "domain": "Social"},
