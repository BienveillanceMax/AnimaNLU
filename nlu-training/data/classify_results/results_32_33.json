  {"text": "Non, je vois rien", "speech_act": "Deny", "domain": "Social"},
  {"text": "Peyton, barre-toi", "speech_act": "Command", "domain": "Social"},
  {"text": "T'aimerais bien, ouais", "speech_act": "Statement", "domain": "Social"},
  {"text": "Bien sûr. Mes amis me manquent", "speech_act": "Statement", "domain": "Social"},
  {"text": "Dis moi que je rêve !", "speech_act": "Request", "domain": "Social"},
