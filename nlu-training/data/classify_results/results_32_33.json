  {"text": "Finalement la soirée va être intéressante", "speech_act": "Statement", "domain": "Social"},
  {"text": "Au Japon ?", "speech_act": "Question", "domain": "Knowledge"},
  {"text": "Lève l'appareil, que j'entende !", "speech_act": "Command", "domain": "Communication"},
  {"text": "Oh, non, non, non, non. Nous ne sommes pas mariés", "speech_act": "Deny", "domain": "Social"},
  {"text": "Je suis navrée que vous vous sentiez offensée", "speech_act": "Statement", "domain": "Social"},
  {"text": "Whouhou !", "speech_act": "ExpressEmotion", "domain": "Social"},
  {"text": "Tu entend?", "speech_act": "Question", "domain": "Social"},
