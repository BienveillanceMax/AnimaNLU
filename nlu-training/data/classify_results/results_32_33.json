  {"text": "J'aurais pu le tabasser", "speech_act": "Statement", "domain": "Social"},
  {"text": "Pourquoi seulement aujourd'hui ?", "speech_act": "Question", "domain": "Social"},
  {"text": "Mais hé", "speech_act": "Statement", "domain": "Social"},
  {"text": "Surtout, faites comme si je n'étais pas là", "speech_act": "Request", "domain": "Social"},
